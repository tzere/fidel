:root {
  --bg: #efe7d7;
  --surface: rgba(255, 249, 241, 0.88);
  --surface-strong: rgba(255, 252, 247, 0.94);
  --surface-dark: rgba(34, 55, 61, 0.94);
  --text: #1d2930;
  --muted: #5b6a70;
  --accent: #bf6d3a;
  --accent-deep: #87431f;
  --warm: #f3cda9;
  --sage: #90a48b;
  --gold: #e7bb63;
  --line: rgba(29, 41, 48, 0.12);
  --success: #2f7d57;
  --error: #b94d40;
  --shadow: 0 24px 56px rgba(50, 37, 24, 0.17);
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  min-height: 100vh;
  overflow-x: hidden;
  color: var(--text);
  font-family: 'Aptos', 'Segoe UI Variable', 'Noto Sans Ethiopic', sans-serif;
  font-size: 1.08rem;
  background: linear-gradient(180deg, #eadfcf 0%, #efe7d7 100%);
}

body::before {
  display: none;
}
button,
select,
input,
textarea {
  font: inherit;
}

button {
  cursor: pointer;
  border: none;
  transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
}

button:hover {
  transform: translateY(-1px);
}

button:active {
  transform: translateY(0);
}

button:disabled {
  cursor: not-allowed;
  opacity: 0.5;
  transform: none;
}
.page-shell {
  position: relative;
  min-height: 100vh;
  padding: clamp(18px, 2.8vw, 28px);
  overflow: hidden;
  isolation: isolate;
}

.page-shell::before {
  content: '';
  position: absolute;
  inset: 4px;
  border-radius: 30px;
  background: url('assets/edyat-frame.png') center center / 100% 100% no-repeat;
  pointer-events: none;
  z-index: 0;
}

.page-shell > * {
  position: relative;
  z-index: 1;
}

.sun-glow,
.mesh {
  display: none;
}
#app {
  position: relative;
  z-index: 1;
  max-width: 1280px;
  min-width: 0;
  margin: 0 auto;
}

.studio-shell,
.workspace,
.home-main,
.home-side,
.activity-stack,
.roadmap-stack,
.admin-user-list {
  display: grid;
  gap: 16px;
}

.card {
  min-width: 0;
  background: var(--surface);
  border: 1px solid rgba(255, 255, 255, 0.72);
  border-radius: 28px;
  box-shadow: var(--shadow);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  overflow: hidden;
}

.top-shell {
  display: grid;
  grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.95fr);
  gap: 22px;
  padding: 22px;
}

.eyebrow,
.activity-badge {
  display: inline-flex;
  align-items: center;
  padding: 7px 12px;
  border-radius: 999px;
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.eyebrow {
  background: rgba(255, 249, 239, 0.82);
  color: var(--accent-deep);
}

.activity-badge {
  background: rgba(243, 205, 169, 0.54);
  color: var(--accent-deep);
}

h1,
.section-title,
.view-title,
.activity-title,
.symbol-display,
.profile-name {
  font-family: 'Aptos Display', 'Trebuchet MS', 'Noto Sans Ethiopic', sans-serif;
}

h1 {
  margin: 14px 0 10px;
  font-size: clamp(2.9rem, 5vw, 5.3rem);
  line-height: 0.95;
  letter-spacing: -0.04em;
}

.section-title,
.view-title {
  margin: 0 0 10px;
  font-size: 2rem;
}

.activity-title {
  margin: 12px 0 8px;
  font-size: 1.45rem;
}

.hero-copy,
.panel-copy,
.activity-copy,
.metric-label,
.helper-copy,
.message,
.roadmap-text,
.field-label,
.profile-label,
.admin-meta {
  color: var(--muted);
  line-height: 1.6;
}

.menu-side {
  display: grid;
  gap: 16px;
}

.main-menu,
.auth-form,
.selector-row,
.mode-nav,
.activity-actions,
.metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.auth-form {
  flex-direction: column;
}

.menu-btn,
.primary-btn,
.secondary-btn,
.ghost-btn,
.chip-btn,
.symbol-btn,
.variant-btn {
  min-height: 46px;
  padding: 0 16px;
  border-radius: 16px;
  font-weight: 700;
}

.menu-btn,
.ghost-btn,
.chip-btn,
.variant-btn {
  background: rgba(255, 255, 255, 0.72);
  border: 1px solid rgba(29, 41, 48, 0.08);
  color: var(--text);
}

.menu-btn.is-active,
.chip-btn.is-active,
.variant-btn.is-active {
  background: rgba(191, 109, 58, 0.14);
  color: var(--accent-deep);
  border-color: rgba(191, 109, 58, 0.28);
}

.primary-btn {
  background: linear-gradient(135deg, var(--accent), #dc8650);
  color: #fff8f2;
  box-shadow: 0 14px 26px rgba(191, 109, 58, 0.22);
}

.secondary-btn {
  background: rgba(34, 55, 61, 0.94);
  color: #f9f4eb;
}

.profile-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  padding: 16px 18px;
  border-radius: 22px;
  background: rgba(34, 55, 61, 0.9);
  color: #faf4ec;
}

.profile-label {
  font-size: 0.78rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: rgba(250, 244, 236, 0.7);
}

.profile-name {
  font-size: 1.4rem;
}

.banner-card,
.auth-card,
.welcome-card,
.side-card,
.panel-card,
.challenge-celebration {
  padding: 22px;
}

.banner-card.is-success {
  background: rgba(47, 125, 87, 0.14);
}

.banner-card.is-error {
  background: rgba(185, 77, 64, 0.14);
}

.auth-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 18px;
}

.admin-auth-grid {
  grid-template-columns: minmax(0, 560px);
}

.home-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.95fr);
  gap: 18px;
}

.activity-card,
.variant-summary,
.admin-section {
  padding: 18px;
  border-radius: 22px;
  background: rgba(255, 255, 255, 0.64);
  border: 1px solid rgba(29, 41, 48, 0.08);
}

.variant-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.variant-summary.is-locked {
  opacity: 0.6;
}

.variant-summary.is-complete {
  background: rgba(47, 125, 87, 0.14);
}

.variant-meta {
  font-size: 0.86rem;
  font-weight: 700;
  color: var(--accent-deep);
}

.workspace-top,
.panel-head,
.symbol-caption {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14px;
}

.top-shell > *,
.workspace-top > *,
.panel-head > *,
.symbol-caption > *,
.home-grid > *,
.auth-grid > * {
  min-width: 0;
}

.panel-card {
  background: var(--surface-strong);
}

.field-label {
  display: block;
  margin-bottom: 6px;
  font-weight: 700;
}

.field-input,
.selector,
.textarea-field {
  width: 100%;
  min-height: 46px;
  padding: 0 14px;
  border-radius: 14px;
  border: 1px solid rgba(29, 41, 48, 0.14);
  background: rgba(255, 255, 255, 0.92);
  color: var(--text);
}

.textarea-field {
  min-height: 140px;
  padding: 14px;
  resize: vertical;
}

.message-box,
.hint-box {
  padding: 14px 16px;
  border-radius: 18px;
  border: 1px solid rgba(29, 41, 48, 0.08);
  background: rgba(255, 255, 255, 0.76);
}

.message-box.is-success {
  background: rgba(47, 125, 87, 0.12);
}

.message-box.is-error {
  background: rgba(185, 77, 64, 0.12);
}

.hint-box {
  background: rgba(243, 205, 169, 0.24);
}

.metrics,
.stat-strip,
.admin-copy-grid {
  display: grid;
  gap: 12px;
}

.metrics {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.metrics.two-up {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.stat-strip {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.compact-strip {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.metric,
.stat-pill {
  padding: 14px;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.74);
  border: 1px solid rgba(29, 41, 48, 0.08);
}

.metric-value {
  font-size: 1.8rem;
  font-weight: 800;
}

.stat-pill strong {
  display: block;
  font-size: 1.35rem;
}

.variant-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
  gap: 12px;
}

.letter-grid,
.explorer-grid,
.drag-bank {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(84px, 1fr));
  gap: 12px;
}

.symbol-display {
  display: grid;
  place-items: center;
  min-height: 220px;
  margin: 10px 0 14px;
  border-radius: 28px;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(243, 205, 169, 0.52));
  border: 1px solid rgba(29, 41, 48, 0.08);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
  font-size: clamp(5rem, 12vw, 8rem);
}

.symbol-btn {
  min-height: 108px;
  font-size: 2.8rem;
  background: rgba(255, 255, 255, 0.8);
  border: 1px solid rgba(29, 41, 48, 0.08);
}

.symbol-btn.is-correct {
  background: rgba(47, 125, 87, 0.16);
  color: var(--success);
}

.variant-btn.is-locked {
  opacity: 0.45;
}

.challenge-celebration {
  background: linear-gradient(135deg, rgba(255, 244, 224, 0.92), rgba(243, 205, 169, 0.72));
}

.challenge-celebration.is-final {
  background: linear-gradient(135deg, rgba(255, 243, 222, 0.94), rgba(231, 187, 99, 0.72));
}

.drop-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
  gap: 12px;
  margin-top: 18px;
}

.drop-slot {
  display: grid;
  gap: 10px;
  align-items: start;
  min-height: 132px;
  padding: 14px;
  border-radius: 22px;
  border: 2px dashed rgba(135, 67, 31, 0.28);
  background: rgba(255, 255, 255, 0.72);
  text-align: left;
}

.drop-slot.is-filled {
  border-style: solid;
  background: rgba(243, 205, 169, 0.34);
}

.drop-label {
  font-size: 0.88rem;
  font-weight: 800;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--accent-deep);
}

.drop-value {
  align-self: center;
  justify-self: center;
  font-size: 3rem;
}

.admin-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.admin-copy-grid {
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
}

.admin-field,
.admin-user-card {
  min-width: 0;
}

.admin-meta {
  margin-top: 6px;
}

.dragdrop-celebration {
  border: 1px solid rgba(135, 67, 31, 0.18);
  box-shadow: 0 18px 36px rgba(191, 109, 58, 0.18);
  animation: dragdrop-celebration-pop 260ms ease-out;
}

@keyframes dragdrop-celebration-pop {
  0% {
    transform: translateY(12px) scale(0.98);
    opacity: 0.2;
  }

  100% {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
}

@media (max-width: 1024px) {
  .top-shell,
  .home-grid {
    grid-template-columns: 1fr;
  }

  .metrics,
  .metrics.two-up,
  .stat-strip,
  .compact-strip {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 720px) {
  body {
    font-size: 1rem;
  }

  .page-shell {
    padding: 12px 10px 20px;
  }

  h1 {
    font-size: 2.45rem;
  }

  .section-title,
  .view-title {
    font-size: 1.6rem;
  }

  .activity-title {
    font-size: 1.25rem;
  }

  .workspace-top,
  .panel-head,
  .symbol-caption,
  .profile-bar {
    flex-direction: column;
    align-items: stretch;
  }

  .metrics,
  .metrics.two-up,
  .stat-strip,
  .compact-strip {
    grid-template-columns: 1fr;
  }

  .symbol-btn {
    min-height: 92px;
    font-size: 2.2rem;
  }

  .drop-value {
    font-size: 2.5rem;
  }
}
